DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require
# Comma-separated browser origins allowed to call the API (no trailing slash).
# Include your live game URL + local Vite. Wildcard example: https://*.vercel.app
ALLOWED_ORIGINS=https://basket-hop.vercel.app,http://localhost:5173,http://127.0.0.1:5173
LEADERBOARD_MAX_SCORE=9999
LEADERBOARD_RATE_LIMIT_WINDOW_MS=60000
LEADERBOARD_RATE_LIMIT_MAX_REQUESTS=12
VITE_API_BASE_URL=
# Railway WebSocket match server (wss://your-service.up.railway.app)
VITE_MP_WS_URL=
# Exact browser origins accepted by the Railway WebSocket server.
MP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MP_HEARTBEAT_TIMEOUT_MS=45000
